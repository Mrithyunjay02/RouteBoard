              "raw": "{\n  \"vehicleNumber\": \"V-9999\",\n  \"origin\": \"New York\",\n  \"destination\": \"Boston\",\n  \"scheduledStart\": \"2026-08-01T10:00:00Z\",\n  \"notes\": \"Extra fragile cargo\",\n  \"driverId\": 2\n}"
            }
          }
        },
